{
  "name": "@neevparikh/pirouette",
  "version": "0.12.5",
  "description": "Long-lived pi coding agents in the cloud, with a web dashboard and a CLI.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/neevparikh/pirouette.git"
  },
  "author": "Neev Parikh",
  "bin": {
    "pirouette": "dist/cli/index.js",
    "pru": "dist/cli/index.js"
  },
  "main": "dist/cli/index.js",
  "files": [
    "dist/",
    "scripts/",
    "pirouette.toml",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "npm run vendor && tsc -p tsconfig.build.json && node scripts/post-build.mjs",
    "vendor": "node scripts/vendor.mjs",
    "clean": "rm -rf dist",
    "themes": "node scripts/generate-themes.mjs",
    "prepublishOnly": "npm run clean && npm run typecheck && npm test && npm run build",
    "dev": "npm run vendor && tsx src/cli/index.ts server",
    "pru": "tsx src/cli/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "spike:session:new": "tsx src/spikes/session-resume.ts new",
    "spike:session:resume": "tsx src/spikes/session-resume.ts resume",
    "spike:session:inspect": "tsx src/spikes/session-resume.ts inspect",
    "spike:session:reset": "tsx src/spikes/session-resume.ts reset",
    "spike:stream:serve": "tsx src/spikes/event-streaming.ts serve",
    "spike:stream:client": "tsx src/spikes/event-streaming.ts client",
    "spike:stream:reset": "tsx src/spikes/event-streaming.ts reset"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "commander": "^13.1.0",
    "smol-toml": "^1.6.1",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.1",
    "@types/ws": "^8.18.1",
    "dompurify": "^3.4.1",
    "highlight.js": "^11.11.1",
    "isomorphic-dompurify": "^2.36.0",
    "jsdom": "^25.0.1",
    "marked": "^15.0.12",
    "marked-highlight": "^2.2.4",
    "playwright": "^1.60.0",
    "tsx": "^4.20.6",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4"
  }
}
